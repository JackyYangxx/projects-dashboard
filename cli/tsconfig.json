{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "../cli-dist",
    "rootDir": ".",
    "esModuleInterop": true
  },
  "include": ["./**/*.ts"],
  "exclude": ["**/__tests__/**", "**/*.test.ts"]
}
