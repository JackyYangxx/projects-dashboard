{
  "appId": "com.precisioncurator.app",
  "productName": "Precision Curator",
  "directories": {
    "output": "release"
  },
  "asar": false,
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "public/**/*"
  ],
  "icon": "docs/app-icon",
  "mac": {
    "target": [
      {
        "target": "dmg",
        "arch": ["arm64"]
      }
    ],
    "category": "public.app-category.productivity",
    "icon": "docs/app-icon"
  },
  "win": {
    "target": [
      {
        "target": "zip",
        "arch": ["x64", "arm64"]
      }
    ],
    "defaultArch": "x64",
    "signAndEditExecutable": false,
    "icon": "docs/app-icon"
  },
  "linux": {
    "target": ["AppImage", "deb"],
    "category": "Utility",
    "icon": "docs/app-icon"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  }
}
