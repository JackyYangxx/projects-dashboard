{
  "appId": "com.precisioncurator.app",
  "productName": "Precision Curator",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "public/**/*"
  ],
  "mac": {
    "target": ["dmg"],
    "category": "public.app-category.productivity"
  },
  "win": {
    "target": ["nsis"]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  }
}
